  <div class="video-modal" id="videoModal" onclick="if(event.target.id==='videoModal')closeVideo()">
    <button class="video-close" onclick="closeVideo()" aria-label="Fermer">×</button>
    <video id="lindaVideo" controls playsinline preload="metadata" webkit-playsinline></video>
    <div class="caption">
      <span class="name" id="videoName">Linda</span>
      <span id="videoDesc" data-fr="On vous présente Linda, super jument espagnole, robe Isabelle, 15 ans." data-en="Meet Linda, a wonderful Spanish mare, Isabella coat, 15 years old.">On vous présente Linda, super jument espagnole, robe Isabelle, 15 ans.</span>
    </div>
  </div>
</div>

<script>

  // === Pony videos (MP4 H.264 baseline) — Blob URLs on demand ===
  const PONY_VIDEOS = {
    linda: {
      name: "Linda",
      birthYear: 2015,
      desc_fr: "On vous présente Linda, ponette D espagnole de {age} ans.",
      desc_en: "Meet Linda, a Spanish D-class pony, {age} years old.",
      videoUrl: "/videos/linda.mp4"
    },
    halia: {
      name: "Halia",
      birthYear: 2020,
      desc_fr: "On vous présente Halia, douce jument franches-montagnes suisse de {age} ans.",
      desc_en: "Meet Halia, a gentle Swiss Franches-Montagnes mare, {age} years old.",
      videoUrl: "/videos/halia.mp4"
    },
    middy: {
      name: "Middy",
      desc_fr: "On vous présente Middy.",
      desc_en: "Meet Middy.",
      videoUrl: "/videos/middy.mp4"
    }
  };
  function getPonyVideoUrl(id){
    const data = PONY_VIDEOS[id];
    return data ? data.videoUrl : null;
  }




  let currentLang = 'fr';

  function applyLang(){
    document.querySelectorAll('[data-fr]').forEach(el => {
      const txt = el.getAttribute('data-' + currentLang);
      if(txt) el.textContent = txt;
    });
    document.documentElement.lang = currentLang;
    const tog = document.getElementById('langToggle');
    if(tog) tog.textContent = currentLang === 'fr' ? 'EN' : 'FR';
  }

  function setLang(l){
    currentLang = l;
    applyLang();
    go('home');
  }

  function toggleLang(){
    currentLang = currentLang === 'fr' ? 'en' : 'fr';
    applyLang();
  }


  // Calcule l'âge à partir de l'année de naissance — change automatiquement au 1er janvier
  function computeAge(birthYear){
    return new Date().getFullYear() - birthYear;
  }

  function openVideo(id){
    const modal = document.getElementById('videoModal');
    const video = document.getElementById('lindaVideo');
    const data = PONY_VIDEOS[id];
    if(!data) return;
    const url = getPonyVideoUrl(id);
    if(url) video.src = url;
    document.getElementById('videoName').textContent = data.name;
    // Substitute {age} dynamically with the current age
    const age = data.birthYear ? computeAge(data.birthYear) : '';
    const descFr = data.desc_fr.replace('{age}', age);
    const descEn = data.desc_en.replace('{age}', age);
    const descEl = document.getElementById('videoDesc');
    descEl.setAttribute('data-fr', descFr);
    descEl.setAttribute('data-en', descEn);
    descEl.textContent = currentLang === 'fr' ? descFr : descEn;
    modal.classList.add('open');
    try { video.currentTime = 0; video.play().catch(()=>{}); } catch(e){}
  }
  function closeVideo(){
    const modal = document.getElementById('videoModal');
    const video = document.getElementById('lindaVideo');
    try { video.pause(); } catch(e){}
    modal.classList.remove('open');
  }

  function go(name){
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    const target = document.getElementById('screen-' + name);
    if(target) target.classList.add('active');
    const sa = target.querySelector('.scroll-area');
    if(sa) sa.scrollTop = 0;
  }

  setTimeout(() => {
    if(document.getElementById('screen-splash').classList.contains('active')){
      go('lang');
    }
  }, 5000);
</script>
