<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="theme-color" content="#1A130C" />
<title>Equi'Roul Club</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --cream: #1A130C;        /* fond principal sombre (expresso) */
    --cream-2: #251A11;      /* fond secondaire */
    --paper: #2A1F16;        /* surface des cartes */
    --paper-2: #3A2A1E;      /* surface en relief */
    --bronze: #D9BE8E;       /* bronze clair, vif sur sombre */
    --bronze-deep: #B8956A;  /* bronze moyen */
    --gold: #E8D5B0;         /* doré clair */
    --gold-soft: #F0E0BD;    /* doré très clair */
    --ink: #F5EBD7;          /* texte principal — ivoire */
    --ink-2: #C9B894;        /* texte secondaire */
    --muted: #8C7556;        /* texte muet */
    --line: #3D2D1F;         /* lignes / bordures */
  }

  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
  html,body{
    height:100%;
    width:100%;
    overscroll-behavior:none;
  }
  body{
    font-family:'Jost', system-ui, sans-serif;
    background: var(--cream);
    color:var(--ink);
    overflow:hidden;
    position:fixed;
    inset:0;
  }

  /* ============ APP CONTAINER ============ */
  .app{
    width:100%;
    height:100%;
    background:var(--cream);
    position:relative;
    overflow:hidden;
    display:flex;
    flex-direction:column;
  }

  /* ============ SCREENS ============ */
  .screen{
    position:absolute;
    inset:0;
    display:none;
    flex-direction:column;
    overflow:hidden;
  }
  .screen.active{ display:flex; animation: fadeUp .45s ease both; }
  @keyframes fadeUp{
    from{opacity:0; transform:translateY(8px);}
    to{opacity:1; transform:translateY(0);}
  }

  /* ============ SPLASH ============ */
  #screen-splash{
    background:
      radial-gradient(circle at 50% 30%, #3A2A1E 0%, var(--cream) 50%, #0F0A06 100%);
    align-items:center;
    justify-content:center;
    text-align:center;
    padding:40px 32px;
  }
  .splash-ornament{
    width:60%;
    max-width:240px;
    height:1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin:18px 0;
    opacity:0;
    animation: lineGrow 1.2s ease 1.4s forwards;
  }
  @keyframes lineGrow{ from{opacity:0;transform:scaleX(0);} to{opacity:.7;transform:scaleX(1);} }

  .splash-welcome{
    font-family:'Cormorant Garamond', serif;
    font-style:italic;
    font-weight:400;
    font-size:clamp(22px, 6vw, 28px);
    color:var(--bronze-deep);
    letter-spacing:.04em;
    opacity:0;
    animation: slideDown .8s ease .2s forwards;
  }
  @keyframes slideDown{
    from{opacity:0; transform:translateY(-12px);}
    to{opacity:1; transform:translateY(0);}
  }

  .splash-logo{
    width:min(92%, 440px);
    margin: 24px 0 18px;
    opacity:0;
    transform:scale(.92);
    animation: logoIn 1.4s cubic-bezier(.2,.7,.3,1) .6s forwards;
    filter: drop-shadow(0 8px 22px rgba(160,120,69,.25));
  }
  @keyframes logoIn{
    from{opacity:0; transform:scale(.92);}
    to{opacity:1; transform:scale(1);}
  }

  .splash-tagline{
    font-family:'Cinzel', serif;
    font-size:11px;
    letter-spacing:.5em;
    color:var(--bronze);
    text-transform:uppercase;
    opacity:0;
    animation: fadeUp .8s ease 1.6s forwards;
    margin-top:8px;
  }

  .splash-subtagline{
    font-family:'Cormorant Garamond', serif;
    font-style:italic;
    font-size:18px;
    color:var(--gold-soft);
    letter-spacing:.03em;
    opacity:0;
    animation: fadeUp .8s ease 1.9s forwards;
    margin-top:14px;
  }

  .splash-loader{
    position:absolute;
    bottom:60px;
    left:50%;
    transform:translateX(-50%);
    display:flex;
    gap:6px;
    opacity:0;
    animation: fadeUp .6s ease 2s forwards;
  }
  .splash-loader span{
    width:6px; height:6px; border-radius:50%;
    background:var(--gold);
    animation: pulse 1.4s ease infinite;
  }
  .splash-loader span:nth-child(2){ animation-delay:.2s; }
  .splash-loader span:nth-child(3){ animation-delay:.4s; }
  @keyframes pulse{
    0%,100%{opacity:.3; transform:scale(1);}
    50%{opacity:1; transform:scale(1.3);}
  }

  /* ============ LANGUAGE ============ */
  #screen-lang{
    background: var(--cream);
    align-items:center;
    justify-content:center;
    padding:40px 32px;
    text-align:center;
  }
  .lang-emblem{
    display:flex; align-items:center; justify-content:center;
    margin-bottom:30px;
  }
  .lang-title{
    font-family:'Cinzel', serif;
    font-size:13px;
    letter-spacing:.45em;
    color:var(--bronze);
    text-transform:uppercase;
    margin-bottom:10px;
  }
  .lang-sub{
    font-family:'Cormorant Garamond', serif;
    font-style:italic;
    font-size:18px;
    color:var(--ink-2);
    margin-bottom:36px;
    line-height:1.5;
  }
  .lang-options{ display:flex; flex-direction:column; gap:14px; width:100%; max-width:280px; }
  .lang-btn{
    background:var(--paper);
    border:1px solid var(--line);
    border-radius:14px;
    padding:18px 20px;
    display:flex; align-items:center; justify-content:space-between;
    cursor:pointer;
    transition: all .25s ease;
    font-family:'Jost',sans-serif;
  }
  .lang-btn:active{
    transform:scale(.98);
    border-color:var(--bronze);
  }
  .lang-btn .flag{
    font-size:24px;
  }
  .lang-btn .lname{
    flex:1;
    text-align:left;
    margin-left:14px;
    font-weight:500;
    color:var(--ink);
    letter-spacing:.04em;
  }
  .lang-btn .arrow{
    color:var(--bronze);
    font-size:20px;
  }

  /* ============ TOP BAR ============ */
  .top-bar{
    display:flex;
    align-items:center;
    padding: max(env(safe-area-inset-top), 18px) 20px 14px;
    background: var(--cream);
    border-bottom:1px solid var(--line);
    position:relative;
    z-index:5;
    flex-shrink:0;
  }
  .top-bar .back{
    width:38px; height:38px;
    border-radius:50%;
    background:var(--paper);
    border:1px solid var(--line);
    display:flex; align-items:center; justify-content:center;
    cursor:pointer;
    color:var(--bronze);
    font-size:22px;
    transition: all .2s;
  }
  .top-bar .back:active{ background:var(--bronze); color:#fff; transform:scale(.95); }
  .top-bar .title{
    flex:1;
    text-align:center;
    font-family:'Cinzel', serif;
    font-size:13px;
    letter-spacing:.35em;
    color:var(--bronze-deep);
    text-transform:uppercase;
    margin-right:38px;
  }

  .scroll-area{
    flex:1;
    overflow-y:auto;
    -webkit-overflow-scrolling:touch;
    scrollbar-width:none;
    padding-bottom: env(safe-area-inset-bottom);
  }
  .scroll-area::-webkit-scrollbar{ display:none; }

  /* ============ HOME ============ */
  #screen-home .hero{
    padding: max(env(safe-area-inset-top), 30px) 24px 26px;
    text-align:center;
    background:
      radial-gradient(ellipse at top, rgba(216,180,130,.12) 0%, transparent 70%),
      var(--cream);
    border-bottom:1px solid var(--line);
    position:relative;
    flex-shrink:0;
  }

  #screen-home .hero .est{
    font-family:'Cormorant Garamond', serif;
    font-style:italic;
    font-size:14px;
    color:var(--muted);
    letter-spacing:.18em;
  }
  .lang-toggle{
    position:absolute;
    top: max(env(safe-area-inset-top), 28px);
    right:18px;
    background:var(--paper);
    border:1px solid var(--line);
    border-radius:20px;
    padding:6px 12px;
    font-size:12px;
    font-family:'Jost',sans-serif;
    font-weight:600;
    color:var(--bronze);
    cursor:pointer;
    letter-spacing:.05em;
    transition:transform .15s;
  }
  .lang-toggle:active{ transform:scale(.94); }

  .menu-grid{
    padding: 22px 18px 12px;
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap:12px;
  }
  .menu-card{
    background:var(--paper);
    border:1px solid var(--line);
    border-radius:18px;
    padding:24px 14px 22px;
    cursor:pointer;
    transition: all .2s ease;
    display:flex;
    flex-direction:column;
    align-items:center;
    text-align:center;
    min-height:140px;
    justify-content:center;
    position:relative;
    overflow:hidden;
  }
  .menu-card:active{
    transform:scale(.97);
    border-color:var(--gold);
  }
  .menu-card .icon{
    font-size:30px;
    margin-bottom:12px;
    color:var(--bronze);
  }
  .menu-card .label{
    font-family:'Cinzel', serif;
    font-size:11px;
    letter-spacing:.18em;
    color:var(--ink);
    text-transform:uppercase;
    line-height:1.4;
  }
  .menu-card.full{
    grid-column: span 2;
    flex-direction:row;
    justify-content:flex-start;
    text-align:left;
    min-height: 70px;
    padding: 18px 22px;
    gap:14px;
  }
  .menu-card.full .icon{ margin-bottom:0; font-size:24px; }

  .home-footer{
    text-align:center;
    padding: 20px 24px 28px;
    margin-top: 12px;
    border-top:1px solid var(--line);
    background:linear-gradient(180deg, transparent, rgba(242,233,216,.5));
  }
  .home-footer .quote{
    font-family:'Cormorant Garamond', serif;
    font-style:italic;
    font-size:15px;
    color:var(--ink-2);
    line-height:1.5;
  }
  .home-footer .sig{
    font-family:'Cinzel', serif;
    font-size:10px;
    letter-spacing:.35em;
    color:var(--gold);
    margin-top:10px;
  }

  /* ============ INNER PAGE COMMON ============ */
  .page-hero{
    text-align:center;
    padding: 22px 24px 24px;
    border-bottom:1px solid var(--line);
    background:
      radial-gradient(ellipse at top, rgba(216,180,130,.12) 0%, transparent 70%);
    flex-shrink:0;
  }
  .page-hero .kicker{
    font-family:'Cinzel', serif;
    font-size:10px;
    letter-spacing:.4em;
    color:var(--bronze);
    text-transform:uppercase;
  }
  .page-hero h1{
    font-family:'Cormorant Garamond', serif;
    font-weight:500;
    font-size:34px;
    color:var(--ink);
    margin-top:6px;
    line-height:1.1;
  }
  .page-hero .ornament{
    width:40px; height:1px;
    background: var(--gold);
    margin:14px auto 0;
  }

  /* ============ TEAM ============ */
  .team-list{ padding: 18px 18px 30px; display:flex; flex-direction:column; gap:14px; }
  .pony-card{
    background:var(--paper);
    border:1px solid var(--line);
    border-radius:18px;
    overflow:hidden;
    display:flex;
  }
  .pony-photo{
    width:115px;
    height:115px;
    flex-shrink:0;
    background:
      linear-gradient(135deg, var(--paper-2) 0%, #4A3826 100%);
    display:flex; align-items:center; justify-content:center;
    color:var(--bronze-deep);
    font-size:34px;
    border-right:1px solid var(--line);
  }
  .pony-info{ flex:1; padding:14px 16px; display:flex; flex-direction:column; justify-content:center; }
  .pony-name{
    font-family:'Cormorant Garamond', serif;
    font-weight:600;
    font-size:23px;
    color:var(--ink);
  }
  .pony-role{
    font-family:'Cinzel', serif;
    font-size:9.5px;
    letter-spacing:.25em;
    color:var(--bronze);
    text-transform:uppercase;
    margin-top:3px;
  }
  .pony-desc{
    font-size:12px;
    color:var(--ink-2);
    margin-top:6px;
    line-height:1.4;
  }
  .upload-hint{
    text-align:center;
    padding:18px;
    background:var(--paper);
    border:1px dashed var(--gold-soft);
    border-radius:14px;
    color:var(--muted);
    font-family:'Cormorant Garamond', serif;
    font-style:italic;
    font-size:13px;
    margin-top:6px;
  }

  /* ============ TARIFS ============ */
  .tarifs-wrap{ padding: 18px 18px 30px; }
  .tarif-section{
    background:var(--paper);
    border:1px solid var(--line);
    border-radius:18px;
    padding:18px 18px 8px;
    margin-bottom:14px;
  }
  .tarif-section h3{
    font-family:'Cinzel', serif;
    font-size:11px;
    letter-spacing:.3em;
    color:var(--bronze);
    text-transform:uppercase;
    margin-bottom:14px;
    padding-bottom:10px;
    border-bottom:1px solid var(--line);
  }
  .tarif-row{
    display:flex;
    justify-content:space-between;
    align-items:baseline;
    padding:10px 0;
    border-bottom:1px dotted var(--line);
  }
  .tarif-row:last-child{ border-bottom:none; }
  .tarif-name{
    font-family:'Jost', sans-serif;
    font-size:14px;
    color:var(--ink);
    flex:1;
  }
  .tarif-name small{ display:block; color:var(--muted); font-size:11px; margin-top:1px; font-weight:400; }
  .tarif-price{
    font-family:'Cormorant Garamond', serif;
    font-weight:600;
    font-size:20px;
    color:var(--bronze-deep);
  }
  .tarif-price.demande{ font-style:italic; font-size:13px; color:var(--bronze); font-weight:500; }

  .conditions{
    background: linear-gradient(135deg, var(--cream-2), var(--cream));
    border:1px solid var(--gold-soft);
    border-radius:18px;
    padding:18px;
    margin-top:8px;
  }
  .conditions h3{
    font-family:'Cinzel', serif;
    font-size:11px;
    letter-spacing:.3em;
    color:var(--bronze-deep);
    text-transform:uppercase;
    margin-bottom:12px;
  }
  .conditions ul{ list-style:none; }
  .conditions li{
    font-size:12.5px;
    color:var(--ink-2);
    padding:7px 0 7px 20px;
    position:relative;
    line-height:1.45;
  }
  .conditions li::before{
    content:'❦';
    position:absolute;
    left:0; top:7px;
    color:var(--gold);
    font-size:11px;
  }

  .cta-wa{
    margin-top:14px;
    background: var(--bronze-deep);
    color:#fff;
    border-radius:14px;
    padding:18px;
    text-align:center;
    cursor:pointer;
    transition:all .2s;
    text-decoration:none;
    display:block;
  }
  .cta-wa:active{ background:var(--bronze); transform:scale(.98); }
  .cta-wa .label{
    font-family:'Cinzel', serif;
    font-size:10px;
    letter-spacing:.3em;
    color:var(--gold-soft);
    text-transform:uppercase;
  }
  .cta-wa .num{
    font-family:'Cormorant Garamond', serif;
    font-size:24px;
    font-weight:500;
    margin-top:4px;
    letter-spacing:.05em;
  }

  /* ============ ACTIVITIES ============ */
  .act-list{ padding:18px 18px 30px; display:flex; flex-direction:column; gap:14px; }
  .act-card{
    background:var(--paper);
    border:1px solid var(--line);
    border-radius:18px;
    padding:20px;
    cursor:pointer;
    transition:all .2s;
  }
  .act-card:active{ transform:scale(.98); border-color:var(--gold); }
  .act-icon{
    width:50px; height:50px;
    border-radius:50%;
    background: linear-gradient(135deg, var(--paper-2), #4A3826);
    display:flex; align-items:center; justify-content:center;
    font-size:24px;
    color:var(--bronze-deep);
    margin-bottom:14px;
  }
  .act-name{
    font-family:'Cormorant Garamond', serif;
    font-size:22px;
    font-weight:600;
    color:var(--ink);
    line-height:1.15;
  }
  .act-tag{
    font-family:'Cinzel', serif;
    font-size:9.5px;
    letter-spacing:.25em;
    color:var(--bronze);
    text-transform:uppercase;
    margin-top:5px;
  }
  .act-desc{
    font-size:13px;
    color:var(--ink-2);
    margin-top:10px;
    line-height:1.5;
  }

  /* ============ CONTACT ============ */
  .contact-wrap{ padding:18px 18px 30px; }
  .contact-card{
    background:var(--paper);
    border:1px solid var(--line);
    border-radius:18px;
    padding:24px;
    margin-bottom:14px;
    text-align:center;
    text-decoration:none;
    display:block;
    color:inherit;
    transition:all .2s;
  }
  a.contact-card:active{ transform:scale(.98); border-color:var(--gold); }
  .contact-card .c-icon{
    width:56px; height:56px;
    border-radius:50%;
    background: linear-gradient(135deg, var(--paper-2), #4A3826);
    display:inline-flex; align-items:center; justify-content:center;
    font-size:24px;
    color:var(--bronze-deep);
    margin-bottom:14px;
  }
  .contact-card .label{
    font-family:'Cinzel', serif;
    font-size:10px;
    letter-spacing:.3em;
    color:var(--bronze);
    text-transform:uppercase;
    margin-bottom:8px;
  }
  .contact-card .value{
    font-family:'Cormorant Garamond', serif;
    font-size:21px;
    font-weight:500;
    color:var(--ink);
    line-height:1.3;
  }

  /* ============ LOCATION ============ */
  .map-wrap{ padding:18px 18px 30px; }
  .map-preview{
    background: linear-gradient(135deg, #4A3826, #2F2316);
    border:1px solid var(--gold-soft);
    border-radius:18px;
    height:240px;
    position:relative;
    overflow:hidden;
    display:flex;
    align-items:center;
    justify-content:center;
    margin-bottom:14px;
  }
  .map-preview::before{
    content:'';
    position:absolute;
    inset:0;
    background:
      linear-gradient(0deg, rgba(0,0,0,.12), transparent),
      repeating-linear-gradient(45deg, transparent 0 30px, rgba(255,255,255,.08) 30px 31px),
      repeating-linear-gradient(-45deg, transparent 0 30px, rgba(255,255,255,.08) 30px 31px);
  }
  .map-pin{
    position:relative;
    z-index:2;
    width:54px; height:54px;
    border-radius:50% 50% 50% 0;
    background: var(--bronze-deep);
    transform:rotate(-45deg);
    display:flex; align-items:center; justify-content:center;
    box-shadow: 0 8px 16px rgba(0,0,0,.3);
    animation: bounce 2s ease infinite;
  }
  .map-pin::after{
    content:'';
    width:20px; height:20px;
    background:var(--gold);
    border-radius:50%;
    transform:rotate(45deg);
  }
  @keyframes bounce{
    0%,100%{ transform:rotate(-45deg) translateY(0); }
    50%{ transform:rotate(-45deg) translateY(-10px); }
  }
  .map-address{
    background:var(--paper);
    border:1px solid var(--line);
    border-radius:14px;
    padding:18px;
    text-align:center;
    margin-bottom:12px;
  }
  .map-address .name{
    font-family:'Cormorant Garamond', serif;
    font-size:22px;
    font-weight:600;
    color:var(--ink);
  }
  .map-address .addr{
    font-size:13.5px;
    color:var(--ink-2);
    margin-top:6px;
    line-height:1.5;
  }
  .map-btn{
    background: var(--bronze-deep);
    color:#fff;
    border-radius:14px;
    padding:18px;
    text-align:center;
    cursor:pointer;
    transition:all .2s;
    text-decoration:none;
    display:block;
  }
  .map-btn:active{ background:var(--bronze); transform:scale(.98); }
  .map-btn .lab{
    font-family:'Cinzel', serif;
    font-size:11px;
    letter-spacing:.3em;
    text-transform:uppercase;
  }


  .splash-logo svg, svg.splash-logo { display:block; }
  .lang-logo-svg{
    width:300px; max-width:80vw; height:auto;
    filter: drop-shadow(0 6px 18px rgba(160,120,69,.22));
  }
  .home-logo-svg{
    width:min(200px, 52vw); height:auto;
    margin-bottom:8px;
    filter: drop-shadow(0 4px 12px rgba(160,120,69,.2));
  }


  /* ===== Video card (Linda) ===== */
  .pony-card-video{ cursor:pointer; }
  .pony-photo-video{
    position:relative;
    padding:0;
    background:#1a120a;
    overflow:hidden;
  }
  .pony-photo-video img.thumb{
    width:100%;
    height:100%;
    object-fit:cover;
    display:block;
  }
  .play-overlay{
    position:absolute; inset:0;
    display:flex; align-items:center; justify-content:center;
    background: linear-gradient(135deg, rgba(0,0,0,.05), rgba(0,0,0,.35));
    transition: background .25s;
  }
  .pony-card-video:active .play-overlay{ background: rgba(0,0,0,.5); }
  .play-btn{
    width:46px; height:46px;
    border-radius:50%;
    background: rgba(245,235,215,.95);
    display:flex; align-items:center; justify-content:center;
    color: var(--bronze-deep);
    font-size:18px;
    padding-left:4px;
    box-shadow: 0 6px 18px rgba(0,0,0,.45);
  }

  /* ===== Video modal ===== */
  .video-modal{
    position:fixed; inset:0;
    background: rgba(10,7,4,.94);
    z-index:1000;
    display:none;
    flex-direction:column;
    align-items:center; justify-content:center;
    padding: max(env(safe-area-inset-top), 60px) 20px max(env(safe-area-inset-bottom), 20px);
    backdrop-filter: blur(6px);
    gap:18px;
  }
  .video-modal.open{ display:flex; animation: fadeIn .25s ease; }
  @keyframes fadeIn{ from{opacity:0} to{opacity:1} }
  .video-modal video, .video-modal img{
    max-width:100%;
    max-height:75%;
    border-radius:16px;
    box-shadow: 0 20px 60px rgba(0,0,0,.6);
    background:#000;
  }
  .video-modal .caption{
    max-width:520px;
    padding: 0 12px;
    text-align:center;
    color: var(--ink);
    font-family:'Cormorant Garamond', serif;
    font-style:italic;
    font-size:17px;
    line-height:1.5;
    opacity:.92;
  }
  .video-modal .caption .name{
    display:block;
    font-family:'Cinzel', serif;
    font-style:normal;
    font-size:12px;
    letter-spacing:.35em;
    color: var(--bronze);
    text-transform:uppercase;
    margin-bottom:8px;
  }
  .video-close{
    position:absolute;
    top: max(env(safe-area-inset-top), 18px);
    right:18px;
    width:42px; height:42px;
    border-radius:21px;
    background: rgba(245,235,215,.12);
    border:1px solid rgba(245,235,215,.25);
    color: var(--ink);
    font-size:24px; line-height:1;
    display:flex; align-items:center; justify-content:center;
    cursor:pointer;
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    padding:0; padding-bottom:3px;
  }


